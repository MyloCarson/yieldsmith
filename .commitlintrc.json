{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore",
        "ci",
        "revert"
      ]
    ],
    "type-case": [2, "always", "lower-case"],
    "type-empty": [2, "never"],
    "subject-empty": [2, "never"],
    "subject-full-stop": [2, "never", "."],
    "subject-case": [2, "never", ["start-case", "pascal-case", "upper-case"]],
    "header-max-length": [2, "always", 72],
    "body-leading-blank": [2, "always"],
    "footer-leading-blank": [2, "always"]
  },
  "prompt": {
    "questions": {
      "type": {
        "description": "Select the type of change you're making"
      },
      "subject": {
        "description": "Write a short imperative tense description of the change"
      },
      "body": {
        "description": "Provide a longer description of the change (optional). Use | for new lines"
      },
      "footer": {
        "description": "List any breaking changes or issues closed by this change (optional)"
      }
    }
  }
}
