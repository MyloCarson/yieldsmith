{
  "name": "yieldsmith",
  "version": "0.1.0",
  "description": "Telegram bot for NGX dividend stock monitoring and AI-powered investment recommendations",
  "main": "dist/index.js",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.json\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --loader ts-node/esm supabase/migrations/run.ts",
    "db:seed": "psql -f supabase/seed.sql",
    "prepare": "husky install",
    "precommit": "pnpm format && pnpm lint:fix && pnpm typecheck && pnpm test"
  },
  "keywords": [
    "telegram",
    "ngx",
    "dividend",
    "stocks",
    "bot",
    "investment",
    "supabase"
  ],
  "author": "Seun Akanni",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.5.0",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "telegraf": "^4.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix",
      "jest --bail --findRelatedTests"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
