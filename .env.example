# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Provider Configuration (Default: Claude)
AI_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
# Optional: Uncomment to use Gemini instead
# GEMINI_API_KEY=your-gemini-api-key-here
# Optional: Uncomment to use OpenAI instead
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Notification Provider (Default: Telegram, already configured above)
NOTIFICATION_PROVIDER=telegram
# Optional: Slack notifications
# SLACK_BOT_TOKEN=xoxb-your-slack-token
# Optional: Discord notifications
# DISCORD_BOT_TOKEN=your-discord-token

# Data Provider Configuration (Default: NGX Pulse)
DATA_PROVIDER=ngx_pulse
NGX_PULSE_API_KEY=your_ngx_pulse_api_key_here
# Optional: Alpha Vantage for US stocks
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/yieldsmith

# Feature Flags
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_PRICE_ALERTS=true
ENABLE_DIVIDEND_ALERTS=true
ENABLE_REBALANCING_SUGGESTIONS=true

# Market Configuration
DEFAULT_MARKET=ngx
ENABLED_MARKETS=ngx

# Portfolio Goals (Can also be set per-user)
ANNUAL_DIVIDEND_GOAL=500000
MONTHLY_INVESTMENT_AMOUNT=200000

# Cache Configuration
CACHE_TTL_SECONDS=3600
PRICE_CACHE_TTL_SECONDS=3600

# Rate Limiting with Upstash Redis
# Sign up: https://upstash.com (free tier includes 10K commands/day)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Rate limit thresholds (can be overridden in config/rate-limits.config.json)
RATE_LIMIT_PER_SECOND=30
API_RATE_LIMIT_PER_MINUTE=100
RECOMMENDATIONS_PER_DAY=5
MESSAGES_PER_MINUTE=10

# Retry Configuration
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000

# Development
DEBUG=false
VERBOSE_LOGGING=false
